# ── CORE SETUP (required, ~10 minutes) ──────────────────────────────────────
#
# Gmail — your work email address + an App Password (NOT your regular password)
# Get an app password: myaccount.google.com/apppasswords
# (Requires 2-factor auth to be enabled on your Google account)
GMAIL_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=

# Slack — Incoming Webhook URL for #speed-to-lead alerts
# Get a webhook: api.slack.com/apps → Create App → Incoming Webhooks → Add to Workspace → pick channel → copy URL
SLACK_WEBHOOK_URL=

# Anthropic — for Claude Haiku draft generation (falls back to templates if not set)
# Get a key: console.anthropic.com
ANTHROPIC_API_KEY=

# [Company] calendar link — included in all draft emails
COMPANY_CALENDAR_LINK=https://calendly.com/[company]/demo


# ── OPTIONAL: 1v1 Slack Bot (advanced setup, separate guide) ─────────────────
#
# Enables the SDR to DM the bot directly in Slack for lead context and drafts.
# Requires creating a Slack app with Socket Mode — see workflows/slack_interface.md
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=


# ── OPTIONAL: Apollo.io enrichment ───────────────────────────────────────────
#
# Adds real company name, headcount, job title, and LinkedIn data to each lead.
# Without this, enrichment is keyword-based from the email body (still works well).
# Free tier: 50 enrichments/month.
# Get a key: apollo.io → Settings → Integrations → API → Create Key
APOLLO_API_KEY=


# ── OPTIONAL: Instantly integration ──────────────────────────────────────────
#
# Scans Instantly unibox for unread replies
INSTANTLY_API_KEY=
